{
  "name": "my-siblings",
  "version": "0.1.0",
  "private": true,
  "description": "My Siblings: a lifetime platform turning loneliness into belonging.",
  "scripts": {
    "css:build": "tailwindcss -i ./app/globals.css -o ./public/site.css --config ./tailwind.config.ts",
    "migrate": "node ./scripts/migrate.mjs",
    "dev": "node ./scripts/dev.mjs",
    "build": "next build",
    "prebuild": "npm run css:build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 100",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:dev:android": "npx cap run android",
    "cap:dev:ios": "npx cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.462.0",
    "mysql2": "^3.22.3",
    "next": "^15.0.0",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
